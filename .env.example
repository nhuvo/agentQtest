# =====================================================
# QA Copilot — Environment Template
# Copy file này thành .env rồi điền key thật
# cp .env.example .env
# =====================================================

# ── AI Provider ──────────────────────────────────────
# Giá trị hợp lệ: anthropic | gemini | openai | qwen | gemma | minimax
AI_PROVIDER=anthropic

# ── Model override (để trống = dùng mặc định theo provider) ──
# AI_MODEL=

# ── API Keys ─────────────────────────────────────────
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
OPENAI_API_KEY=

# ── GreenNode AgentBase (cho Qwen / Gemma / MiniMax) ─
GREENODE_API_KEY=
GREENNODE_BASE_URL=https://api.greennode.ai/v1

# ── App Security ──────────────────────────────────────
# Để trống = chỉ localhost. Đặt key = team phải nhập key này vào UI.
APP_API_KEY=

# ── Server ────────────────────────────────────────────
APP_ENV=development
# production / team: đổi thành 0.0.0.0 để nhận kết nối từ mạng
APP_HOST=127.0.0.1
APP_PORT=8000

# ── CORS ──────────────────────────────────────────────
# Dùng * để cho phép mọi origin (team truy cập từ nhiều máy)
ALLOWED_ORIGINS=http://localhost:8000

# ── Rate Limiting ─────────────────────────────────────
RATE_LIMIT_PER_MIN=20

# ── Smart Routing (Anthropic only) ────────────────────
# true = tự chọn haiku/sonnet theo độ phức tạp CAP (giảm chi phí)
# false = luôn dùng model mặc định
SMART_ROUTING=true

# =====================================================
# TEAM DEPLOYMENT — copy section này vào .env thật
# =====================================================
#
# 1. Tìm IP máy bạn:   ipconfig getifaddr en0   (Mac)
#                      ip route get 1 | awk '{print $7}'  (Linux)
#
# 2. Đặt các biến sau:
#    APP_HOST=0.0.0.0
#    APP_PORT=8000
#    APP_API_KEY=your-secret-key-here   ← team sẽ nhập key này vào UI
#    ALLOWED_ORIGINS=*
#
# 3. Khởi động:  python3 app.py
#
# 4. Team truy cập:  http://<IP-của-bạn>:8000
#    Nhập APP_API_KEY vào ô 🔑 góc trên phải — lưu tự động vào browser.
# =====================================================
